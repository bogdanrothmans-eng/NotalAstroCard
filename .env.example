# Telegram bot (from @BotFather)
BOT_TOKEN=123456:ABC-your-bot-token

# Shared secret for webhook authenticity. Set the same value when calling
# setWebhook (the script does this for you). Use a long random string.
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Public base URL of the deployed Mini App (used by scripts/set-webhook.ts).
# e.g. https://your-app.vercel.app  — the webhook becomes <base>/api/telegram/webhook
PUBLIC_BASE_URL=https://your-app.vercel.app

# libSQL / SQLite. Local dev: a file. Production (Vercel): a Turso database URL.
# Local:      file:./local.db
# Production: libsql://your-db.turso.io   (+ TURSO_AUTH_TOKEN)
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=
